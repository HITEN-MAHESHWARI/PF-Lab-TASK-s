#include <stdio.h>

int main() {
    char a[50];
    int i = 0;
    int vowel = 0, consonant = 0;
    
    printf("Enter a word: ");
    scanf("%s", a);
    
    while(a[i] != '\0'){
    if(a[i] == 'A' || a[i] == 'E' || a[i] == 'I' || a[i] == 'O' || a[i] == 'U' || a[i] == 'a' || a[i] == 'e' || a[i] == 'i' || a[i] == 'o' || a[i] == 'u'){
    	vowel++;
	}
	else{
		consonant++;
	}
	i++;
}
    printf("Vowel: %d\n", vowel);	
    printf("consonant: %d", consonant);

    return 0;
}
