#include <stdio.h>

int main() {
    int a[10];
    int num;
    int i;
    int count = 0;
    
    printf("Enter 10 integer: ");
    for(i = 0; i < 10; i++){
    scanf("%d", &a[i]);
    }
    
    printf("Enter any number: ");
    scanf("%d", &num);
    
    for(i = 0; i < 10; i++){
            if(a[i] == num){
                count++;
            }
    }
    
            if(count > 0){
                printf("Number is repeated %d times ", count);
            }
            else{
                printf("Number not found");
            }

    return 0;
}
