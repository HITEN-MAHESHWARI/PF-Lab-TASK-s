#include <stdio.h>

int main() {
    char a[50];
    int i = 0;
    
    printf("Enter a sentence: ");
    scanf("%[^\n]", &a[i]);
    
    while(a[i] != '\0'){
    if(a[i]>='A' && a[i] <= 'Z'){
    	a[i] = a[i] + 32;
	}
	else if(a[i]>='a' && a[i] <= 'z'){
		a[i] = a[i] - 32;
	}
	i++;
}
    printf("%s", a);	

    return 0;
}
