#include <stdio.h>

int main() {
    int a[10];
    int i;
    int max;
    int mini;
    int difference;
    
    printf("Enter 10 integer: ");
    for(i = 0; i < 10; i++){
        scanf("%d", &a[i]);
    }
    max = mini = a[0];
    for(i = 1; i < 10; i++){
        if(max < a[i]){
        max = a[i];
        }
        else if(mini > a[i]){
            mini = a[i];
        }
    }
    difference = max - mini;
    printf("Difference is: %d", difference);

    return 0;
}
