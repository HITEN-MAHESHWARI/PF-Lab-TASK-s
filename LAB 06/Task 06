#include <stdio.h>
int main() {
    double salary;
    
    printf("Enter the initial salary: ");
    scanf("%lf", &salary);
    for(int i = 1; i <= 10; i++){
        salary = salary * 1.05;
        printf("Year %d Salary: %.2lf\n", i, salary);
    }
    printf("Your total salary after 10 year is: %.2lf", salary);
    
    return 0;
}
