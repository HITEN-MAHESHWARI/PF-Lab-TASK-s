#include <stdio.h>

int main() {
    int arr[6] = {40, 50, 60, 30, 20, 45};
    int *p = arr;
    int highest = *p;

    for (int i = 0; i < 6; i++)
        if (*(p + i) > highest)
            highest = *(p + i);

    printf("Before Scaling:\n");
    for (int i = 0; i < 6; i++)
        printf("%d ", *(p + i));

    for (int i = 0; i < 6; i++)
        *(p + i) = (int)(((float)*(p + i) / highest) * 100);

    printf("\nAfter Scaling:\n");
    for (int i = 0; i < 6; i++)
        printf("%d ", *(p + i));

    return 0;
}
